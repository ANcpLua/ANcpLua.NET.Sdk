<Project>
  <!--
    ANcpSdkPackageVersion is a placeholder stamped at pack time by build.ps1 from the
    CI-computed version (see .github/workflows/nuget-publish.yml compute_version job).
    Do not set a real version here — the placeholder is intentional.
  -->
  <PropertyGroup Label="SDK Version (Auto-generated)">
    <ANcpSdkPackageVersion>999.9.9</ANcpSdkPackageVersion>
  </PropertyGroup>

  <PropertyGroup Label=".NET SDK">
    <DotNetSdkVersion>10.0.300</DotNetSdkVersion>
    <DotNetSdkRollForward>latestMinor</DotNetSdkRollForward>
  </PropertyGroup>

  <PropertyGroup Label="Roslyn">
    <RoslynVersion>5.6.0</RoslynVersion>
    <RoslynAnalyzersVersion>5.3.0</RoslynAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="Reference Assemblies">
    <BasicReferenceAssembliesVersion>1.8.8</BasicReferenceAssembliesVersion>
  </PropertyGroup>

  <PropertyGroup Label="Meziantou">
    <MeziantouFrameworkVersion>5.0.19</MeziantouFrameworkVersion>
    <MeziantouFullPathVersion>2.0.1</MeziantouFullPathVersion>
    <MeziantouProcessWrapperVersion>1.0.14</MeziantouProcessWrapperVersion>
    <MeziantouTemporaryDirectoryVersion>2.0.1</MeziantouTemporaryDirectoryVersion>
  </PropertyGroup>

  <PropertyGroup Label="Testing">
    <XunitV3Version>3.2.2</XunitV3Version>
    <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
    <AwesomeAssertionsAnalyzersVersion>9.0.8</AwesomeAssertionsAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="MTP Extensions">
    <MTPExtensionsVersion>2.2.3</MTPExtensionsVersion>
    <CodeCoverageVersion>18.7.0</CodeCoverageVersion>
    <GitHubActionsLoggerMTPVersion>3.0.4</GitHubActionsLoggerMTPVersion>
  </PropertyGroup>

  <PropertyGroup Label="Analyzers">
    <!-- 2.1.0: adds AL1506 (ExcludeFromCodeCoverage on branching code without a Justification),
         on top of 2.0.2's gating of the AL1200-band "use ANcpLua.Roslyn.Utilities helper" rules
         (AL1204-AL1220) to projects that reference the package. 2.1.0 is indexed on nuget.org —
         pointing SDK truth at an unpublished version fails restore with NU1102.
         Bundled per-rule editorconfig in src/Config/Analyzer.ANcpLua.Analyzers.editorconfig
         is regenerated from the published DLL's HelpLinkUri by ConfigFilesGenerator. -->
    <ANcpLuaAnalyzersVersion>2.1.0</ANcpLuaAnalyzersVersion>
    <NetAnalyzersVersion Condition="'$(NetAnalyzersVersion)' == ''">$(DotNetSdkVersion)</NetAnalyzersVersion>
    <SbomTargetsVersion>4.1.5</SbomTargetsVersion>
    <BannedApiAnalyzersVersion>4.14.0</BannedApiAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Extensions">
    <MicrosoftExtensionsVersion>10.6.0</MicrosoftExtensionsVersion>
    <AspNetCoreVersion>10.0.8</AspNetCoreVersion>
    <MicrosoftBclAsyncInterfacesVersion>10.0.8</MicrosoftBclAsyncInterfacesVersion>
  </PropertyGroup>

  <PropertyGroup Label="Build Tools">
    <NuGetVersion>7.6.0</NuGetVersion>
    <MSBuildStructuredLoggerVersion>2.3.204</MSBuildStructuredLoggerVersion>
  </PropertyGroup>

  <!-- OpenApi.Readers has no stable 2.0; still on preview. -->
  <PropertyGroup Label="OpenAPI">
  </PropertyGroup>

  <!--
    Microsoft.Agents.AI (MAF 1.4.0). Numeric base ships in lockstep from upstream;
    family spans mixed release tracks — highest experimental track per package:
      stable     : core, Abstractions, Workflows, OpenAI
      -preview.* : Hosting, Hosting.AGUI.AspNetCore, Anthropic, DevUI
      -rc1       : Workflows.Declarative
    Mismatched numeric bases break assembly binding. Mismatched tracks within
    the same numeric base are what upstream actually ships — keep aligned, accept
    the suffix variance.
  -->
  <PropertyGroup Label="Microsoft.Agents">
    <MicrosoftAgentsAIVersion Condition="'$(MicrosoftAgentsAIVersion)' == ''">1.4.0</MicrosoftAgentsAIVersion>
    <MicrosoftAgentsAIAbstractionsVersion Condition="'$(MicrosoftAgentsAIAbstractionsVersion)' == ''">1.4.0</MicrosoftAgentsAIAbstractionsVersion>
    <MicrosoftAgentsAIWorkflowsVersion Condition="'$(MicrosoftAgentsAIWorkflowsVersion)' == ''">1.4.0</MicrosoftAgentsAIWorkflowsVersion>
    <MicrosoftAgentsAIOpenAIVersion Condition="'$(MicrosoftAgentsAIOpenAIVersion)' == ''">1.4.0</MicrosoftAgentsAIOpenAIVersion>
    <MicrosoftAgentsAIHostingVersion Condition="'$(MicrosoftAgentsAIHostingVersion)' == ''">1.4.0-preview.260505.1</MicrosoftAgentsAIHostingVersion>
    <MicrosoftAgentsAIHostingAGUIAspNetCoreVersion Condition="'$(MicrosoftAgentsAIHostingAGUIAspNetCoreVersion)' == ''">1.4.0-preview.260505.1</MicrosoftAgentsAIHostingAGUIAspNetCoreVersion>
    <MicrosoftAgentsAIAnthropicVersion Condition="'$(MicrosoftAgentsAIAnthropicVersion)' == ''">1.4.0-preview.260505.1</MicrosoftAgentsAIAnthropicVersion>
    <MicrosoftAgentsAIDevUIVersion Condition="'$(MicrosoftAgentsAIDevUIVersion)' == ''">1.4.0-preview.260505.1</MicrosoftAgentsAIDevUIVersion>
    <MicrosoftAgentsAIWorkflowsDeclarativeVersion Condition="'$(MicrosoftAgentsAIWorkflowsDeclarativeVersion)' == ''">1.4.0-rc1</MicrosoftAgentsAIWorkflowsDeclarativeVersion>
  </PropertyGroup>

  <PropertyGroup Label="Aliases">
    <XunitMtpVersion>$(XunitV3Version)</XunitMtpVersion>
  </PropertyGroup>
</Project>
