<Project>
  <!--
    ANcpSdkPackageVersion is a placeholder stamped at pack time by build.ps1 from the
    CI-computed version (see .github/workflows/nuget-publish.yml compute_version job).
    Do not set a real version here — the placeholder is intentional.
  -->
  <PropertyGroup Label="SDK Version (Auto-generated)">
    <ANcpSdkPackageVersion>999.9.9</ANcpSdkPackageVersion>
  </PropertyGroup>

  <PropertyGroup Label=".NET SDK">
    <DotNetSdkVersion>10.0.300</DotNetSdkVersion>
    <DotNetSdkRollForward>latestMinor</DotNetSdkRollForward>
  </PropertyGroup>

  <PropertyGroup Label="Roslyn">
    <RoslynVersion>5.3.0</RoslynVersion>
    <RoslynAnalyzersVersion>5.3.0</RoslynAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="Analyzer Testing">
  </PropertyGroup>

  <PropertyGroup Label="Reference Assemblies">
    <BasicReferenceAssembliesVersion>1.8.8</BasicReferenceAssembliesVersion>
  </PropertyGroup>

  <PropertyGroup Label="Meziantou">
    <MeziantouFrameworkVersion>5.0.19</MeziantouFrameworkVersion>
    <MeziantouFullPathVersion>2.0.1</MeziantouFullPathVersion>
    <MeziantouProcessWrapperVersion>1.0.14</MeziantouProcessWrapperVersion>
    <MeziantouTemporaryDirectoryVersion>2.0.1</MeziantouTemporaryDirectoryVersion>
  </PropertyGroup>

  <PropertyGroup Label="Testing">
    <XunitV3Version>3.2.2</XunitV3Version>
    <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
    <AwesomeAssertionsAnalyzersVersion>9.0.8</AwesomeAssertionsAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="MTP Extensions">
    <MTPExtensionsVersion>2.2.3</MTPExtensionsVersion>
    <CodeCoverageVersion>18.7.0</CodeCoverageVersion>
    <GitHubActionsLoggerMTPVersion>3.0.4</GitHubActionsLoggerMTPVersion>
    <GitHubActionsLoggerVSTestVersion>2.4.1</GitHubActionsLoggerVSTestVersion>
  </PropertyGroup>

  <PropertyGroup Label="Analyzers">
    <!-- 2.0.1: DocsGenerator + per-rule HelpLinkUri anchors + GitHub README replaces dead mintlify URL.
         AL repo HEAD is 90e6431; package indexed on nuget.org 2026-05-26.
         Bundled per-rule editorconfig in src/Config/Analyzer.ANcpLua.Analyzers.editorconfig
         is regenerated from the published DLL's HelpLinkUri by ConfigFilesGenerator. -->
    <ANcpLuaAnalyzersVersion>2.0.1</ANcpLuaAnalyzersVersion>
    <NetAnalyzersVersion Condition="'$(NetAnalyzersVersion)' == ''">$(DotNetSdkVersion)</NetAnalyzersVersion>
    <SbomTargetsVersion>4.1.5</SbomTargetsVersion>
    <BannedApiAnalyzersVersion>4.14.0</BannedApiAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Extensions">
    <MicrosoftExtensionsVersion>10.6.0</MicrosoftExtensionsVersion>
    <AspNetCoreVersion>10.0.8</AspNetCoreVersion>
    <MicrosoftBclAsyncInterfacesVersion>10.0.8</MicrosoftBclAsyncInterfacesVersion>
  </PropertyGroup>

  <PropertyGroup Label="Build Tools">
    <NuGetVersion>7.6.0</NuGetVersion>
    <MSBuildStructuredLoggerVersion>2.3.204</MSBuildStructuredLoggerVersion>
  </PropertyGroup>

  <!-- OpenApi.Readers has no stable 2.0; still on preview. -->
  <PropertyGroup Label="OpenAPI">
  </PropertyGroup>

  <!--
  -->

  <PropertyGroup Label="LLM Providers">
  </PropertyGroup>

  <PropertyGroup Label="Workflow Testing">
  </PropertyGroup>

  <PropertyGroup Label="Misc">
  </PropertyGroup>

  <PropertyGroup Label="Aliases">
    <XunitMtpVersion>$(XunitV3Version)</XunitMtpVersion>
  </PropertyGroup>
</Project>
