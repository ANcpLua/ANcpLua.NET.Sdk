<?xml version="1.0"?>
<package>
  <metadata>
    <id>ANcpLua.NET.Sdk.Web</id>
    <version>$version$</version>
    <authors>ANcpLua</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>ANcpLua SDK for ASP.NET Core Web projects</description>
    <readme>README.md</readme>
    <license type="expression">MIT</license>
    <repository type="git" url="$RepositoryUrl$" commit="$RepositoryCommit$" branch="$RepositoryBranch$"/>
  </metadata>
  <files>
    <!-- SDK Entry Points -->
    <file src="Sdk/ANcpLua.NET.Sdk.Web/Sdk.props" target="Sdk/Sdk.props"/>
    <file src="Sdk/ANcpLua.NET.Sdk.Web/Sdk.targets" target="Sdk/Sdk.targets"/>

    <!-- Build/Common - Core MSBuild logic -->
    <file src="Build/Common/Common.props" target="Build/Common/"/>
    <file src="Build/Common/Common.targets" target="Build/Common/"/>
    <file src="Build/Common/Version.props" target="Build/Common/"/>
    <file src="Build/Common/ContinuousIntegrationBuild.props" target="Build/Common/"/>
    <file src="Build/Common/Npm.targets" target="Build/Common/"/>
    <file src="Build/Common/Tests.targets" target="Build/Common/"/>
    <file src="Build/Common/GlobalPackages.props" target="Build/Common/"/>
    <file src="Build/Common/SourceGenerators.props" target="Build/Common/"/>

    <!-- Build/Enforcement - Policy, determinism, version checks -->
    <file src="Build/Enforcement/Enforcement.props" target="Build/Enforcement/"/>
    <file src="Build/Enforcement/DeterminismAndSourceLink.props" target="Build/Enforcement/"/>
    <file src="Build/Enforcement/VersionEnforcement.targets" target="Build/Enforcement/"/>

    <!-- Config - Analyzer, style, banned-symbol, and test settings -->
    <file src="Config/*" target="Config/"/>

    <file src="../LICENSE.txt" target=""/>
    <file src="../README.md" target=""/>
  </files>
</package>
